# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'reactNative' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'reactNativeTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Workaround: RN 0.81 bundles fmt 11.0.2 (RN 0.77 used fmt 9.1.0, which did
    # not need this). fmt 11's consteval FMT_STRING path fails to compile under
    # Apple clang from Xcode 26+. fmt's base.h already disables consteval for
    # older Apple clang; widen that guard to all Apple clang. No-op on the Xcode
    # versions RN officially targets (fmt just uses constexpr there) and once
    # patched, so it is safe to keep committed.
    fmt_base = File.join(__dir__, 'Pods/fmt/include/fmt/base.h')
    old_guard = '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L'
    if File.exist?(fmt_base) && (contents = File.read(fmt_base)).include?(old_guard)
      File.chmod(0644, fmt_base) # CocoaPods installs fmt headers read-only
      File.write(fmt_base, contents.sub(old_guard, '#elif defined(__apple_build_version__)'))
      Pod::UI.puts '[backtrace] Patched fmt base.h to disable consteval on Apple clang'.green
    end
  end
end
